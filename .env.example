# ==============================================================================
# GLOBAL PROJECT CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# Database Configuration (Shared across all services)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=campus_central_db
DATABASE_URL=mysql+mysqlconnector://your_db_user:your_db_password@localhost:3306/campus_central_db

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
