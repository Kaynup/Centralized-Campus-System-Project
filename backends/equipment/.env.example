PORT=8001
HOST=0.0.0.0

# Database credentials for raw connection pool
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=campus_central_db

# Business Limits: Exhaustive Usage Limits
# Maximum tokens a student can consume on equipment rentals
MAX_RENTAL_TOKEN_LIMIT=1000.00
