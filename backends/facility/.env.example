# ==============================================================================
# FACILITY SERVICE CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

PORT=8002
HOST=0.0.0.0

# Database URL pointing to shared MySQL
DATABASE_URL=mysql+mysqlconnector://your_db_user:your_db_password@localhost:3306/campus_central_db

# Business Limits: Exhaustive Usage Limits
# Maximum tokens a student can consume on facility reservations
MAX_FACILITY_TOKEN_LIMIT=500.00
