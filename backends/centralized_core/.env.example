# ==============================================================================
# CENTRALIZED CORE SERVICE CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

PORT=8000
HOST=0.0.0.0

# Database URL pointing to shared MySQL
DATABASE_URL=mysql+mysqlconnector://your_db_user:your_db_password@localhost:3306/campus_central_db

# Security & Sessions
JWT_SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Business Logic: Token System
# 1 USD gets converted to 10 Tokens
USD_TO_TOKEN_RATE=10.0
